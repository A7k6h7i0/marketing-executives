<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- HTTPS APIs + OSM tiles on all Android versions / OEM WebViews -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
